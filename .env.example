# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Admin password for data upload
ADMIN_PASSWORD=1234

# Optional: Firebase Service Account JSON (for Firestore persistence)
# If not provided, the app will use an in-memory database for preview purposes.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Optional: JWT Secret for admin sessions
JWT_SECRET=my_super_secret_jwt_key
